{
  "name": "y-sse",
  "description": "HTTP Server-Sent Events (SSE) Provider for Yjs",
  "type": "module",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergey Shishkin",
    "email": "sergey@shishkin.org",
    "url": "https://shishkin.org"
  },
  "homepage": "https://github.com/shishkin/y-sse",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shishkin/y-sse.git"
  },
  "bugs": {
    "url": "https://github.com/shishkin/y-sse/issues"
  },
  "keywords": [
    "yjs",
    "sse",
    "http",
    "crdt"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist/*",
    "src/*"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "check": "tsc -b --noEmit",
    "test": "node --test",
    "build": "tsdown"
  },
  "peerDependencies": {
    "y-protocols": "^1",
    "yjs": "^13"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.14"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./server": "./dist/server.mjs",
      "./package.json": "./package.json"
    }
  }
}
