{
  "include": ["src/**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "node16",
    "lib": [
      "es2024",
      "ESNext.Array",
      "ESNext.Collection",
      "ESNext.Error",
      "ESNext.Iterator",
      "ESNext.Promise",
      "DOM",
      "DOM.AsyncIterable",
    ],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedDeclarations": true,
    "allowImportingTsExtensions": true,
    "declaration": true,
    "noEmit": true,
  },
}
